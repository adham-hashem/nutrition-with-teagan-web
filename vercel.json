{
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|node_modules/|@vite|@react-refresh|@id|src/)[^.]*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cancel-stale-bookings",
      "schedule": "*/10 * * * *"
    }
  ]
}
